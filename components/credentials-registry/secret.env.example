# This component uses a dockerconfigjson secret.
# Credentials are sourced from the project .env file:
#   REGISTRY_USER=<gitlab-username>
#   REGISTRY_TOKEN=<gitlab-token>
#
# Deploy script loads via:
#   kubectl create secret docker-registry <namePrefix>-gitlab-registry-credentials \
#     --docker-server=registry.gitlab.com \
#     --docker-username="$REGISTRY_USER" \
#     --docker-password="$REGISTRY_TOKEN" \
#     --dry-run=client -o yaml | kubectl apply -f -
