# ------------------------------------------------------------------------------
# CI/CD Pipelines – Registry Configuration
# ------------------------------------------------------------------------------
# Copy to .env and fill in values as needed.
# This file is SAFE to commit.
# ------------------------------------------------------------------------------

# Container registry for cicd-pipelines runner images
# Examples:
#   registry.gitlab.com/tomshley/brands/global/tware/tech/products/provisioning/cicd-pipelines
#   ghcr.io/tomshley/cicd-pipelines
# REGISTRY=registry.example.com/org/cicd-pipelines

# Upstream base-containers registry (overrides root Makefile default)
# BASE_CONTAINERS_REGISTRY=registry.gitlab.com/tomshley/brands/global/tware/tech/products/provisioning/base-containers

# ------------------------------------------------------------------------------
# Registry login (OPTIONAL, generic)
# ------------------------------------------------------------------------------
# These variables are loaded by Make's `include` but not referenced by any
# Make target. They are exported to shell commands for docker login.
# Avoid bare `$`, `#`, or `:` in values — Make interprets them as syntax.
#
# Example usage:
#   echo "$REGISTRY_TOKEN" | docker login "$REGISTRY" \
#     -u "$REGISTRY_USER" --password-stdin
# ------------------------------------------------------------------------------

# Registry username (or service account name)
REGISTRY_USER=example-user

# Registry access token / password
# Must have permission to push images
REGISTRY_TOKEN=example-token

# ------------------------------------------------------------------------------
# Git Flow push token (REQUIRED for gitflow finish jobs)
# ------------------------------------------------------------------------------
# Used by .gitflow-jobs.yml to push branches, tags, and merges.
# Create a Project Access Token with `write_repository` scope,
# then set this variable in CI/CD Settings → Variables (masked).
# Without this, CI_JOB_TOKEN is used — which works for push but
# does NOT trigger downstream tag pipelines.
# ------------------------------------------------------------------------------

# Project Access Token with write_repository scope
TOMSHLEY_CICD_GIT_PUSH_TOKEN=example-token

# ------------------------------------------------------------------------------
# Optional build overrides
# ------------------------------------------------------------------------------

# Explicit upstream tag override (defaults to PINNED_PIPELINE_VERSIONS value)
# BASE_CONTAINERS_UPSTREAM_TAG=0.3.0

# Explicit runner tag override
# CICD_PIPELINES_RUNNER_TAG=0.3.0
