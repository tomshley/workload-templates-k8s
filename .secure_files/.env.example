# ------------------------------------------------------------------------------
# CI/CD Pipelines – Registry Configuration
# ------------------------------------------------------------------------------
# Copy to .env and fill in values as needed.
# This file is SAFE to commit.
# ------------------------------------------------------------------------------

# Container registry for cicd-pipelines runner images
# Examples:
#   registry.gitlab.com/tomshley/brands/global/tware/tech/products/provisioning/cicd-pipelines
#   ghcr.io/tomshley/cicd-pipelines
# REGISTRY=registry.example.com/org/cicd-pipelines

# Upstream base-containers registry (overrides root Makefile default)
# BASE_CONTAINERS_REGISTRY=registry.gitlab.com/tomshley/brands/global/tware/tech/products/provisioning/base-containers

# ------------------------------------------------------------------------------
# Registry login (OPTIONAL, generic)
# ------------------------------------------------------------------------------
# These variables are loaded by Make's `include` but not referenced by any
# Make target. They are exported to shell commands for docker login.
# Avoid bare `$`, `#`, or `:` in values — Make interprets them as syntax.
#
# Example usage:
#   echo "$REGISTRY_TOKEN" | docker login "$REGISTRY" \
#     -u "$REGISTRY_USER" --password-stdin
# ------------------------------------------------------------------------------

# Registry username (or service account name)
# REGISTRY_USER=example-user

# Registry access token / password
# Must have permission to push images
# REGISTRY_TOKEN=example-token

# ------------------------------------------------------------------------------
# Optional build overrides
# ------------------------------------------------------------------------------

# Explicit upstream tag override (defaults to PINNED_PIPELINE_VERSIONS value)
# BASE_CONTAINERS_UPSTREAM_TAG=0.3.0

# Explicit runner tag override
# CICD_PIPELINES_RUNNER_TAG=0.3.0

# ------------------------------------------------------------------------------
# Git flow push auth (OPTIONAL — for pipeline triggering on GitLab)
# ------------------------------------------------------------------------------
# On GitLab, CI_JOB_TOKEN pushes don't trigger downstream pipelines.
# Set a Project Access Token (write_repository scope) to enable pipeline
# triggering when flow jobs push branches/tags.
# Not needed on Bitbucket (native push already triggers pipelines).
# ------------------------------------------------------------------------------

# GitLab: Project Access Token with write_repository scope
# Bitbucket: App Password with repository:write scope
# TOMSHLEY_CICD_FLOW_PUSH_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Username for push auth (GitLab adapter defaults to "oauth2")
# Only needed on Bitbucket (set to your Bitbucket username)
# TOMSHLEY_CICD_FLOW_PUSH_USER=my-bb-username

# ------------------------------------------------------------------------------
# Git mirror push (OPTIONAL — for mirror/sync.sh via adapter)
# ------------------------------------------------------------------------------
# Used by the toolbox mirror sync job to push branches/tags to a secondary remote.
# Only needed if your adapter YAML enables the mirror-sync job.
# Mirror auth is completely separate from flow push auth above — mirror targets
# a different remote and uses its own credentials (SSH key or HTTPS token in URL).
# ------------------------------------------------------------------------------

# Mirror remote URL (SSH or HTTPS)
# TOMSHLEY_CICD_MIRROR_URL=git@bitbucket.org:org/repo.git

# SSH private key for mirror auth (path inside .secure_files/)
# Upload the key via GitLab Secure Files, then reference its filename here.
# TOMSHLEY_CICD_MIRROR_SSH_KEY=.secure_files/mirror_deploy_key

# Branches to mirror (comma-separated, default: main)
# TOMSHLEY_CICD_MIRROR_BRANCHES=main

# Mirror tags (default: true)
# TOMSHLEY_CICD_MIRROR_TAGS=true

# Force push to mirror (default: true)
# Use --force to ensure mirror matches origin exactly. Set to false for --force-with-lease.
# TOMSHLEY_CICD_MIRROR_FORCE_PUSH=true

# ------------------------------------------------------------------------------
# Kubernetes imagePullSecrets (OPTIONAL)
# ------------------------------------------------------------------------------
# Name of the K8s Secret containing registry credentials.
# Used by CI to create the Secret and by Kustomize overlays to reference it.
# See examples/image-pull-secret/ for the full patch pattern.
# ------------------------------------------------------------------------------

# Kubernetes imagePullSecrets name (must match a pre-created Secret in the target namespace)
# K8S_IMAGE_PULL_SECRET=my-registry-credentials
